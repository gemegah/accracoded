{
  "name": "accracoded",
  "compatibility_date": "2026-04-16",
  "main": "worker/index.js",
  "assets": {
    "directory": "."
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "accracoded-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "00000000000000000000000000000000"
    }
  ]
}
